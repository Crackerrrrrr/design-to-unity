{
  "schema": "design-to-unity.photoshop-export",
  "schema_version": 1,
  "document": {
    "name": "SamplePanel",
    "width": 400,
    "height": 300,
    "scale": 1,
    "preview": "preview.png",
    "layers": [
      {
        "id": "bg",
        "name": "bg",
        "kind": "pixel",
        "bounds": { "x": 0, "y": 0, "width": 400, "height": 300 },
        "asset": "assets/bg.png"
      },
      {
        "id": "complex_group",
        "name": "btn_start_group",
        "kind": "pixel",
        "role": "button_candidate",
