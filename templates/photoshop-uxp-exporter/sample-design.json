        "bounds": { "x": 90, "y": 220, "width": 160, "height": 56 },
        "asset": "assets/btn_start_group.png",
        "nine_slice": {
          "border": { "left": 16, "right": 16, "top": 12, "bottom": 12 }
        },
        "hasLayerEffects": true
      },
      {
        "id": "title",
        "name": "TitleText",
        "kind": "type",
        "bounds": { "x": 80, "y": 20, "width": 240, "height": 40 },
        "text": {
          "content": "Start VIP",
          "fontFamily": "Inter",
          "fontStyle": "Bold Italic",
          "fontSize": 24,
          "lineHeight": 30,
          "letterSpacing": 1.2,
          "color": "rgba(255,255,255,1)",
          "align": "center",
          "spans": [
            {
              "start": 0,
              "length": 5,
              "style": { "color": "#FFE680", "fontStyle": "Bold" }
            },
            {
              "start": 6,
              "length": 3,
              "style": { "color": "#80D8FF", "fontSize": 20, "fontStyle": "Italic" }
            }
