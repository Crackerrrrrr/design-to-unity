{
  "manifestVersion": 5,
  "id": "com.funplay.design-to-unity.photoshop-exporter",
  "name": "Design to Unity Exporter",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.2.0"
  },
  "requiredPermissions": {
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "designToUnityExporter",
      "label": {
        "default": "Design to Unity"
      },
      "minimumSize": {
        "width": 320,
        "height": 360
      },
      "maximumSize": {
        "width": 1200,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 560
      }
    }
  ]
}
